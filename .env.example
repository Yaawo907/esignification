# ============================================================
# e-Signification Bénin — Variables d'environnement
# ============================================================
#
# Installation :
#   1. Copier :  cp .env.example .env   (Windows : copy .env.example .env)
#   2. Renseigner les valeurs marquées CHANGER
#   3. Générer ENCRYPTION_KEY :
#        python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   4. Générer SECRET_KEY :
#        python -c "import secrets; print(secrets.token_urlsafe(64))"
#
# Le fichier .env est ignoré par Git — ne jamais le committer.
# ============================================================


# ════════════════════════════════════════════════════════════
# DÉVELOPPEMENT LOCAL (valeurs par défaut ci-dessous)
# ════════════════════════════════════════════════════════════

# ── Django ──────────────────────────────────────────────────
SECRET_KEY=CHANGER-cle-secrete-longue-et-aleatoire
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de données ─────────────────────────────────────────
DATABASE_URL=sqlite:///db.sqlite3

# ── Site ────────────────────────────────────────────────────
SITE_URL=http://localhost:8000
ACTIVATION_TOKEN_EXPIRY_HOURS=72

# ── Chiffrement AES-256 Fernet ──────────────────────────────
# Obligatoire — chiffre les PDF et les clés API stockées en base
# ⚠ En prod : clé UNIQUE + sauvegarde hors serveur (perte = données irrécupérables)
ENCRYPTION_KEY=CHANGER-generer-avec-Fernet-generate_key

# ── Email ───────────────────────────────────────────────────
# Dev : emails affichés dans le terminal Django
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=e-Signification Bénin <noreply@esignification.bj>

# ── Celery + Redis ──────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0

# ── SMS (MFA OTP) ───────────────────────────────────────────
# Architecture recommandée (2 niveaux) :
#   1) SMS_BACKEND=custom  → appelle VOTRE API interne
#   2) SMS_GATEWAY_PROVIDER=smspartner → envoi réel via SMSPartner
#
# Dev (terminal uniquement) :
# SMS_BACKEND=console
#
# Prod avec SMSPartner :
# SMS_BACKEND=custom
# SMS_API_URL=http://127.0.0.1:8000/api/v1/sms/
# SMS_API_KEY=CHANGER-cle-secrete-interne-longue
# SMS_SENDER=eSignification
# SMS_GATEWAY_PROVIDER=smspartner
# SMSPARTNER_API_KEY=CHANGER-cle-api-smspartner
# SMSPARTNER_GAMME=1
# SMSPARTNER_WEBHOOK_URL=   # optionnel — callback livraison (URL publique de votre site)
#
# Twilio (alternative) :
# SMS_BACKEND=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+229XXXXXXXX

# Activer l'authentification MFA par SMS dans les profils (huissier, justiciable, admin)
# Tant que false : option grisée « Bientôt disponible »
MFA_SMS_ENABLED=false

# ── Certigna TSA (horodatage — optionnel) ───────────────────
CERTIGNA_TSA_URL=
CERTIGNA_LOGIN=
CERTIGNA_PASSWORD=

# ── Yousign (signature électronique — optionnel) ─────────────
YOUSIGN_API_KEY=
YOUSIGN_API_URL=https://api.yousign.app/v3
# Secret HMAC du webhook (PAS l'URL) — Yousign > Developers > Webhooks > Secret key
# Peut aussi être saisi dans Administration > Configuration > Yousign
YOUSIGN_WEBHOOK_SECRET=
# ALLOWED_HOSTS : séparer par des virgules (pas de point-virgule)
# Ex. ALLOWED_HOSTS=esignification.onrender.com


# ════════════════════════════════════════════════════════════
# PRODUCTION — remplacer les valeurs ci-dessus par celles-ci
# ════════════════════════════════════════════════════════════
#
# SECRET_KEY=<64+ caractères aléatoires — DIFFÉRENT du dev>
# DEBUG=False
# ALLOWED_HOSTS=votre-domaine.bj,www.votre-domaine.bj
#
# DATABASE_URL=postgres://user:motdepasse@host:5432/esignification
#
# SITE_URL=https://votre-domaine.bj
# ACTIVATION_TOKEN_EXPIRY_HOURS=72
#
# ENCRYPTION_KEY=<clé Fernet prod UNIQUE — sauvegarder séparément>
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.hostinger.com
# EMAIL_PORT=465
# EMAIL_USE_TLS=False
# EMAIL_USE_SSL=True
# EMAIL_HOST_USER=noreply@votre-domaine.bj
# EMAIL_HOST_PASSWORD=<mot de passe SMTP>
# DEFAULT_FROM_EMAIL=e-Signification Bénin <noreply@votre-domaine.bj>
#
# CELERY_BROKER_URL=redis://:motdepasse@host-redis:6379/0
#
# ── HTTPS / CSRF (obligatoire quand DEBUG=False) ────────────
# CSRF_TRUSTED_ORIGINS=https://votre-domaine.bj,https://www.votre-domaine.bj
#
# ── HSTS / redirection SSL (activés par défaut si DEBUG=False) ─
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
#
# Pour tester HTTPS sans HSTS (première mise en ligne) :
# SECURE_HSTS_SECONDS=0
#
# ── Vérification avant déploiement ──────────────────────────
# python manage.py check --deploy
# python manage.py collectstatic --noinput
